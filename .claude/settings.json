{
  "permissions": {
    "allow": [
      "Bash(curl -s \"http://localhost:3000/embed/display-center\" -o /tmp/e2.html -w \"HTTP %{http_code}\\\\n\")",
      "Bash(curl -s \"http://localhost:3000/dashboard/share-to-site\" -o /tmp/sts.html -w \"HTTP %{http_code}\\\\n\")",
      "Bash(curl -s -o /tmp/q.html -w '%{http_code}' http://localhost:3000/__TRACKED_VAR__)",
      "Bash(curl -s -o /tmp/ql.html -w \"HTTP %{http_code}\\\\n\" \"http://localhost:3000/dashboard/quotation\")",
      "Bash(curl -s -o /tmp/qd2.html -w \"HTTP %{http_code}\\\\n\" \"http://localhost:3000/dashboard/templates/quotation-detail/variant-1\")",
      "Bash(curl -s -o /tmp/b.html -w '%{http_code}' http://localhost:3000/__TRACKED_VAR__)",
      "Bash(curl -s -o /tmp/s1.html -w \"%{http_code}\" \"http://localhost:3000/dashboard/settings\")",
      "Bash(echo \"[Roles]      $\\(curl -s -o /tmp/s1.html -w \"%{http_code}\" \"http://localhost:3000/dashboard/settings\"\\) | nav:$\\(grep -oE \"User Permissions|Data Setup|Subscription\" /tmp/s1.html)"
    ]
  },
  "enabledPlugins": {
    "agent-skills@addy-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "addy-agent-skills": {
      "source": {
        "source": "directory",
        "path": "./.claude/plugins/agent-skills"
      }
    }
  }
}
